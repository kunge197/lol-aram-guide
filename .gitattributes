# Force LF line endings for GitHub Actions workflows
.github/workflows/* eol=lf
*.yml eol=lf
*.yaml eol=lf

# Force LF for shell scripts
*.sh eol=lf

# Text files - normalize to LF
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.mp4 binary
*.wav binary
